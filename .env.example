# ── Image Cache ───────────────────────────────────────────────
# Admin token for /admin and /campaign-agent UIs
ADMIN_TOKEN=your-admin-token-here

# Heroku Postgres connection string (optional — falls back to file-based JSON)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Express port (default: 3000)
PORT=3000

# URL prefix if mounted under a sub-path (e.g. /image-cache)
BASE_PATH=/image-cache

# ── Campaign Image Agent ──────────────────────────────────────
# Base URL of the Pick app
PICK_API_URL=https://hx-p-i-c-k.vercel.app

# Bearer token for Pick's /api/agent/* endpoints
PICK_AGENT_SECRET=hx-pick-agent-8k4m2x9p7

# How often the agent polls Pick, in milliseconds (default: 60000 = 1 minute)
AGENT_SYNC_INTERVAL=60000
